{
  "name": "plugins-mui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/plugins/mui/src",
  "projectType": "library",
  "tags": ["aglyn:addons"],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/plugins/mui",
        "main": "libs/plugins/mui/src/index.ts",
        "tsConfig": "libs/plugins/mui/tsconfig.lib.json",
        "assets": ["libs/plugins/mui/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/plugins/mui"],
      "options": {
        "jestConfig": "libs/plugins/mui/jest.config.ts"
      }
    }
  }
}
