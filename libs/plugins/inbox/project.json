{
  "name": "plugins-inbox",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/plugins/inbox/src",
  "projectType": "library",
  "tags": ["aglyn:addons"],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/plugins/inbox",
        "main": "libs/plugins/inbox/src/index.ts",
        "tsConfig": "libs/plugins/inbox/tsconfig.lib.json",
        "assets": ["libs/plugins/inbox/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/plugins/inbox"],
      "options": {
        "jestConfig": "libs/plugins/inbox/jest.config.ts"
      }
    }
  }
}
