{
  "name": "besigner-feature-designer",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/besigner/feature/designer/src",
  "projectType": "library",
  "tags": ["scope:lib", "scope:aglyn", "scope:feature", "aglyn:besigner"],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/besigner/feature/designer",
        "main": "libs/besigner/feature/designer/src/index.ts",
        "tsConfig": "libs/besigner/feature/designer/tsconfig.lib.json",
        "assets": ["libs/besigner/feature/designer/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/besigner/feature/designer"],
      "options": {
        "jestConfig": "libs/besigner/feature/designer/jest.config.ts"
      }
    }
  }
}
