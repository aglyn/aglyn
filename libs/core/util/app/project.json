{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/core/util/app/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/core/util/app",
        "main": "libs/core/util/app/src/index.ts",
        "tsConfig": "libs/core/util/app/tsconfig.lib.json",
        "assets": ["libs/core/util/app/*.md"]
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/core/util/app/**/*.ts"]
      }
    }
  },
  "tags": ["scope:lib", "scope:aglyn", "scope:data", "aglyn:framework"]
}
