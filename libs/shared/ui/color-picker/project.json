{
  "name": "shared-ui-color-picker",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/ui/color-picker/src",
  "projectType": "library",
  "tags": ["scope:lib", "scope:shared", "scope:ui"],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/ui/color-picker",
        "main": "libs/shared/ui/color-picker/src/index.ts",
        "tsConfig": "libs/shared/ui/color-picker/tsconfig.lib.json",
        "assets": ["libs/shared/ui/color-picker/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/shared/ui/color-picker"],
      "options": {
        "jestConfig": "libs/shared/ui/color-picker/jest.config.ts"
      }
    }
  }
}
