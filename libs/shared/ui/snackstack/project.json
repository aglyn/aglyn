{
  "name": "shared-ui-snackstack",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/ui/snackstack/src",
  "projectType": "library",
  "tags": ["scope:lib", "scope:shared", "scope:ui"],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared/ui/snackstack",
        "main": "libs/shared/ui/snackstack/src/index.ts",
        "tsConfig": "libs/shared/ui/snackstack/tsconfig.lib.json",
        "assets": ["libs/shared/ui/snackstack/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
